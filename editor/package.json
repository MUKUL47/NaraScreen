{
  "name": "narascreen-editor",
  "version": "1.0.0",
  "description": "NaraScreen visual timeline editor — Electron + React desktop app",
  "author": {
    "name": "Mukul Dutt",
  },
  "homepage": "https://github.com/mukuldutt/narascreen",
  "license": "MIT",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.narascreen.editor",
    "productName": "NaraScreen",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "linux": {
      "target": ["AppImage"],
      "category": "Video",
      "icon": "build/icon.png",
      "extraResources": [
        { "from": "node_modules/ffmpeg-static/ffmpeg", "to": "bin/ffmpeg" },
        { "from": "node_modules/ffprobe-static/bin/linux/${arch}/ffprobe", "to": "bin/ffprobe" }
      ]
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.video",
      "icon": "build/icon.png",
      "extraResources": [
        { "from": "node_modules/ffmpeg-static/ffmpeg", "to": "bin/ffmpeg" },
        { "from": "node_modules/ffprobe-static/bin/darwin/${arch}/ffprobe", "to": "bin/ffprobe" }
      ]
    },
    "win": {
      "target": ["portable"],
      "icon": "build/icon.png",
      "extraResources": [
        { "from": "node_modules/ffmpeg-static/ffmpeg.exe", "to": "bin/ffmpeg.exe" },
        { "from": "node_modules/ffprobe-static/bin/win32/${arch}/ffprobe.exe", "to": "bin/ffprobe.exe" }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
